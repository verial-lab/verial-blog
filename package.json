{
  "name": "verial-blog",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "email:draft": "cd packages/email-templates && npx tsx scripts/send-draft.ts",
    "email:preview": "cd packages/email-templates && npx react-email dev --port 3001"
  },
  "devDependencies": {
    "turbo": "^2.8.3"
  },
  "packageManager": "npm@10.8.0",
  "dependencies": {
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  }
}
