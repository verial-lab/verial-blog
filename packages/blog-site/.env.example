# ─── Verial Blog — Environment Variables ───────────────────────────
# Copy this file to .env.local for local development.
# In production, set these in Vercel → Settings → Environment Variables.
#
# All variables are server-side only (never exposed to the browser).
# ────────────────────────────────────────────────────────────────────

# ── Email (Buttondown) ──────────────────────────────────────────────
# Used by: /api/subscribe
# Get it: buttondown.com → Settings → API → Create key (Subscribers: Write)
BUTTONDOWN_API_KEY=

# ── Feedback (GitHub Issues) ────────────────────────────────────────
# Used by: /api/feedback
# Get it: github.com/settings/tokens?type=beta
#   → Fine-grained token
#   → Resource owner: verial-lab
#   → Repository: verial-lab/verial-blog only
#   → Permissions: Issues → Read and write
GITHUB_FEEDBACK_TOKEN=
