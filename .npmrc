# Disable postinstall scripts to prevent supply chain attacks
# (malicious packages using postinstall to execute arbitrary code)
#
# NOTE: Playwright browsers are NOT installed via postinstall — run manually after npm install:
#   npx playwright install chromium
#
# If a package legitimately needs scripts (e.g. native modules), add it explicitly.
ignore-scripts=true

# Refuse to install packages published less than 2 days ago.
# Newly published versions are a common supply chain attack vector.
# Belt-and-suspenders for npm >= 11.10.0 users. Primary enforcement is scripts/check-package-age.js
# which runs before npm ci and works on any npm version. 7 days per Datadog research.
min-release-age=7
